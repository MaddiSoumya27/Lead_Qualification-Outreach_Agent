# ── Database Configuration ──────────────────────────────────────────────────
# For Render: This will be automatically provided by the PostgreSQL service
DATABASE_URL=postgresql://user:password@hostname:port/database_name
DB_ECHO=false

# ── Authentication & Security ────────────────────────────────────────────────
# REQUIRED: Generate a secure random string for production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── API Server Settings ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── LLM Configuration (Optional - for email drafting) ───────────────────────
# Leave empty for offline mode
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.2

# ── Redis Cache (Optional) ───────────────────────────────────────────────────
# For Render: Use Redis add-on or external Redis service
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_TTL=3600

# ── Enrichment Provider ─────────────────────────────────────────────────────
ENRICHMENT_PROVIDER=mock

# Optional: Real enrichment APIs (for production)
CLEARBIT_API_KEY=sk-your-clearbit-api-key
PDL_API_KEY=your-pdl-api-key

# ── Logging & Monitoring ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true
LOG_FILE_PATH=logs/

# ── Production Settings ──────────────────────────────────────────────────────
# Set these for production deployment
ENVIRONMENT=production
CORS_ORIGINS=https://your-streamlit-app.onrender.com